{
  "name": "sfma",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:nuxt": "vitest run -c vitest.nuxt.config.ts",
    "test:e2e": "playwright test",
    "typecheck": "nuxt typecheck && tsc --noEmit -p packages/shared && tsc --noEmit -p packages/definitions",
    "lint": "eslint .",
    "format": "prettier --write .",
    "verify:bundle": "node infra/scripts/verifyProdBundle.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@babylonjs/core": "^9.12.1",
    "@babylonjs/gui": "^9.12.1",
    "@babylonjs/loaders": "^9.12.1",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.3",
    "@nuxt/ui": "^4.8.2",
    "@nuxtjs/color-mode": "^4.0.1",
    "@nuxtjs/i18n": "^10.4.0",
    "@pinia/nuxt": "^0.11.3",
    "@ptapp/definitions": "workspace:*",
    "@ptapp/shared": "workspace:*",
    "idb": "^8.0.3",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.0",
    "@testing-library/vue": "^8.1.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.5"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,json,yml,yaml,mjs,md}": [
      "prettier --write"
    ]
  }
}
